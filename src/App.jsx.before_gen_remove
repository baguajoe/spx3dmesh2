    if (fn === "live_unwrap")    { if (heMeshRef.current && cameraRef.current) { const uvs = liveUnwrap(heMeshRef.current, cameraRef.current); setStatus(`Live unwrap — ${uvs?.size || 0} vertices`); } return; }
