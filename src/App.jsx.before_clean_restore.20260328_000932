  // ── N panel keyboard shortcut ─────────────────────────────────────────────
  useEffect(() => {
    const onKey = (e) => {
      if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
      const key = e.key;
      if (key === "n" || key === "N") setShowNPanel((v) => !v);
      if (key === "g" || key === "G") window.SPX?.toggleViewport("grid");
      if (key === "q" || key === "Q") setViewportTool("select");
      if (key === "w" || key === "W") setViewportTool("move");
      if (key === "e" || key === "E") setViewportTool("rotate");
      if (key === "r" || key === "R") setViewportTool("scale");
      if ((e.ctrlKey || e.metaKey) && e.altKey && (key === "q" || key === "Q")) {
        e.preventDefault();
        toggleQuadView();
      }
      if (key === "g" || key === "G") window.SPX?.toggleViewport("grid");
      if (key === "w" || key === "W") window.SPX?.toggleViewport("wireframe");
      if ((e.ctrlKey || e.metaKey) && e.altKey && (key === "q" || key === "Q")) {
        e.preventDefault();
        toggleQuadView();
      }
      if (key === "r" || key === "R") window.takeSnapshot?.();
      // Delete selected object
      if (key === "Delete" || key === "Backspace" || key === "x" || key === "X") {
        if (activeObjId) deleteSceneObject(activeObjId);
      }
      // Undo
      if ((e.ctrlKey || e.metaKey) && key === "z") undo();
      // Add primitives
      if (key === "Tab") {
        e.preventDefault();
        setShowNPanel(v => !v);
      }
    };
    window.addEventListener("keydown", onKey);
